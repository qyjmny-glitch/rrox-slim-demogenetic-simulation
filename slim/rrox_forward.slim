function (void) writeGeneticStats(void)
{
    inds = p1.individuals;
    N = size(inds);
    bp = sim.getValue("currentBP");

    if (N == 0)
    {
        line = sim.cycle + "\t" + bp + "\t" + SCENARIO + "\t" + GENETIC_MODE +
               "\t0\t0\tNA\tNA\tNA\tNA\tNA\tNA\tNA\tNA\t0\t" + countFixedDelMuts();
        writeFile(sim.getValue("gen_file"), line, append=T);
        return;
    }

    sampleN = min(c(N, SAMPLE_SIZE));
    sampleInds = sample(inds, sampleN, replace=F);

    fitnessVals = rep(0.0, sampleN);
    twoBVals = rep(0.0, sampleN);
    hetDelVals = rep(0, sampleN);
    homDelVals = rep(0, sampleN);
    weakHetVals = rep(0, sampleN);
    moderateHetVals = rep(0, sampleN);
    strongHetVals = rep(0, sampleN);
    vstrongHetVals = rep(0, sampleN);

    for (i in 0:(sampleN - 1))
    {
        ind = sampleInds[i];

        fitnessVals[i] = individualGeneticFitness(ind);
        twoBVals[i] = individual2B(ind);

        weakHetVals[i] = countHetOfType(ind, m6);
        moderateHetVals[i] = countHetOfType(ind, m5);
        strongHetVals[i] = countHetOfType(ind, m4);
        vstrongHetVals[i] = countHetOfType(ind, m3);

        hetDelVals[i] = weakHetVals[i] + moderateHetVals[i] + strongHetVals[i] + vstrongHetVals[i];
        homDelVals[i] = countHomDel(ind);
    }

    line = sim.cycle + "\t" +
           bp + "\t" +
           SCENARIO + "\t" +
           GENETIC_MODE + "\t" +
           N + "\t" +
           sampleN + "\t" +
           mean(fitnessVals) + "\t" +
           mean(twoBVals) + "\t" +
           mean(hetDelVals) + "\t" +
           mean(homDelVals) + "\t" +
           mean(weakHetVals) + "\t" +
           mean(moderateHetVals) + "\t" +
           mean(strongHetVals) + "\t" +
           mean(vstrongHetVals) + "\t" +
           countSegregatingDelMuts() + "\t" +
           countFixedDelMuts();

    writeFile(sim.getValue("gen_file"), line, append=T);
}

function (void) updateExtinctionStatus(void)
{
    inds = p1.individuals;
    N = size(inds);

    if (N == 0)
    {
        sim.setValue("demographic_extinct", T);
        sim.setValue("functional_extinct", T);
        return;
    }

    females = inds[inds.sex == "F"];
    males = inds[inds.sex == "M"];

    adultFemales = females[(females.age >= FEMALE_MIN_REP_AGE) &
                           (females.age <= FEMALE_MAX_REP_AGE)];
    candidateFathers = getCandidateFathers();

    breedingFemales = adultFemales[sapply(adultFemales, "isBreedingFemale(applyValue);")];

    noBreeder = F;

    if (size(females) == 0 | size(males) == 0)
        noBreeder = T;

    if (size(breedingFemales) == 0 | size(candidateFathers) == 0)
        noBreeder = T;

    if (noBreeder)
        sim.setValue("no_breeder_years", sim.getValue("no_breeder_years") + 1);
    else
        sim.setValue("no_breeder_years", 0);

    if (sim.getValue("no_breeder_years") >= FUNCTIONAL_EXT_YEARS)
        sim.setValue("functional_extinct", T);
}

initialize()
{
    validateScalarParams();

    setSeed(RANDOM_SEED);

    defineConstant("NEUTRAL_CONTROL", GENETIC_MODE == "neutral");

    initializeSLiMModelType("nonWF");
    initializeSLiMOptions(keepPedigrees=T);
    initializeTreeSeq();
    initializeSex("A");

    initializeMutationRate(MU_RATE);

    initializeMutationType("m1", 0.5, "f", 0.0);
    m1.convertToSubstitution = T;

    initializeMutationType("m2", 0.5, "g", DFE_MEAN, DFE_SHAPE);
    m2.convertToSubstitution = F;

    initializeMutationType("m3", 0.0,  "f", 0.0);
    initializeMutationType("m4",  0.01, "f", 0.0);
    initializeMutationType("m5",0.1,  "f", 0.0);
    initializeMutationType("m6",    0.4,  "f", 0.0);

    m3.convertToSubstitution = F;
    m4.convertToSubstitution = F;
    m5.convertToSubstitution = F;
    m6.convertToSubstitution = F;

    initializeGenomicElementType("g1",
        c(m1, m2),
        c(NEUTRAL_FRACTION, DELETERIOUS_FRACTION));

    initializeGenomicElement(g1, 0, GENE_COUNT * GENE_LENGTH - 1);
    initializeRecombinationMapFromCompressedGenome();

    defineConstant("LIFE_MORTALITY", readLifeTableMortality(LIFE_TABLE_FILE, MAX_AGE));
}

// 对forward模拟中新出现的有害突变分类。
// burn-in突变已经在输入tree sequence中完成分类。
// forward期间出现的任何新有害突变在这里处理。
mutation(m2)
{
    sRaw = mut.selectionCoeff;

    if (sRaw > 0.0)
        sRaw = -sRaw;

    sAnnual = sRaw;

    if (sRaw >= -0.01)
        sAnnual = sRaw / GENERATION_TIME;

    if (sRaw < -0.1)
        mut.setMutationType(m3);
    else
    {
        if (sRaw < -0.01)
            mut.setMutationType(m4);
        else
        {
            if (sRaw < -0.001)
                mut.setMutationType(m5);
            else
                mut.setMutationType(m6);
        }
    }

    if (NEUTRAL_CONTROL)
        mut.setSelectionCoeff(0.0);
    else
        mut.setSelectionCoeff(sAnnual);

    return T;
}

1 early()
{
    sim.setValue("life_mortality", LIFE_MORTALITY);
    sim.setValue("climate_factor", readClimateFactor(CLIMATE_FILE));
    sim.setValue("human_factor", readHumanFactor(HUMAN_FILE));
    sim.setValue("hunting_q", readHuntingMortality(HUNTING_FILE));
    sim.setValue("no_breeder_years", 0);
    sim.setValue("functional_extinct", F);
    sim.setValue("demographic_extinct", F);
    sim.setValue("functional_extinction_recorded", F);
    sim.setValue("quasi_extinction_recorded", F);
    sim.setValue("density_factor", 1.0);
    sim.setValue("next_omu_id", 1);
    resetBirthCounters();

    sim.readFromPopulationFile(BURNIN_TREES_IN);

    // 独立forward脚本：加载的burn-in tree sequence可能保留原始burn-in cycle。
    // 为避免歧义，记录forward开始时的cycle，并将该cycle定义为5200 BP。
    sim.setValue("forward_start_cycle", sim.cycle);
    forwardEndCycle = sim.cycle + FORWARD_YEARS;
    sim.setValue("forward_end_cycle", forwardEndCycle);
    community.rescheduleScriptBlock(s1, start=forwardEndCycle, end=forwardEndCycle);
    readBurninSocialState(BURNIN_SOCIAL_STATE_IN);

    // 确保后续OMU id不会与已加载的OMU tag冲突。
    inds = p1.individuals;
    if (size(inds) > 0)
    {
        maxTag = max(inds.tag);
        if (maxTag < 1)
            maxTag = 1;
        sim.setValue("next_omu_id", asInteger(maxTag) + 1);
    }
    else
        sim.setValue("next_omu_id", 1);

    initializeOutputFiles();

    updateEnvironmentForCurrentBP();
    cleanupDominantMales();
    updateSocialStructure();
    writeForwardQALog("pre_breeding");
    applyForwardSurvivalScaling();

    writeEvent("start_forward", "Loaded burn-in tree sequence: " + BURNIN_TREES_IN + "; social state: " + BURNIN_SOCIAL_STATE_IN);

    if (TREESEQ_SAVE_KEYPOINTS == 1)
        treeSeqSave("bp" + START_BP);

    writeDemographyStats("pre_breeding");
    writeGeneticStats();

    catn("Initialized forward run:");
    catn("  SCENARIO     = " + SCENARIO);
    catn("  GENETIC_MODE = " + GENETIC_MODE);
    catn("  BURNIN_IN    = " + BURNIN_TREES_IN);
    catn("  SOCIAL_IN    = " + BURNIN_SOCIAL_STATE_IN);
    catn("  START_BP     = " + START_BP);
    catn("  END_BP       = " + END_BP);
    catn("  N_loaded     = " + p1.individualCount);
}

first()
{
    startCycle = sim.getValue("forward_start_cycle");
    if (isNULL(startCycle))
        return;

    if (sim.cycle > startCycle)
    {
        resetBirthCounters();
        updateEnvironmentForCurrentBP();
        updateSocialStructure();
        if (shouldWriteForwardStats())
            writeForwardQALog("pre_breeding");
    }
}

early()
{
    startCycle = sim.getValue("forward_start_cycle");
    if (isNULL(startCycle))
        return;

    if (sim.cycle > startCycle)
        applyForwardSurvivalScaling();
}

reproduction()
{
    if (individual.sex != "F")
        return;

    if (!isBreedingFemale(individual))
        return;

    father = chooseFather(individual);

    if (isNULL(father))
        return;

    for (b in 1:LITTER_SIZE)
    {
        child = subpop.addCrossed(individual, father);

        child.age = 0;
        child.tag = individual.tag;
        child.tagF = motherTagF(individual);
        incrementBirthCounter(sim.getValue("last_father_category"));

        if (NEWBORNS_EXPERIENCE_AGE0_MORTALITY == 1)
        {
            mortality = sim.getValue("life_mortality");
            densityFactor = sim.getValue("density_factor");
            qHunt = sim.getValue("hunting_q_t");
            child.fitnessScaling = (1.0 - mortality[0]) * (1.0 - qHunt) * densityFactor;
        }
        else
            child.fitnessScaling = 1.0;
    }

    individual.tagF = asFloat(sim.cycle);
}

late()
{
    updateExtinctionStatus();

    currentBP = sim.getValue("currentBP");

    shouldWriteDemo = shouldWriteForwardStats();
    if (shouldWriteDemo)
    {
        writeDemographyStats("post_mortality");
        writeForwardQALog("post_mortality");
    }

    if (p1.individualCount < 100)
        shouldWriteGen = ((sim.cycle - sim.getValue("forward_start_cycle")) % GENETIC_STAT_N_LT100_INTERVAL == 0);
    else
        shouldWriteGen = ((sim.cycle - sim.getValue("forward_start_cycle")) % GENETIC_STAT_INTERVAL == 0);

    if (shouldWriteGen | currentBP == END_BP | p1.individualCount == 0)
        writeGeneticStats();

    if (p1.individualCount == 0)
    {
        writeEvent("demographic_extinction", "N=0 at bp " + currentBP);

        if (TREESEQ_SAVE_KEYPOINTS == 1)
            treeSeqSave("demographic_extinction_bp" + currentBP);

        sim.simulationFinished();
    }

    if (sim.getValue("functional_extinct"))
    {
        if (!sim.getValue("functional_extinction_recorded"))
        {
            sim.setValue("functional_extinction_recorded", T);
            writeEvent("functional_extinction", "no_breeder_years >= " + FUNCTIONAL_EXT_YEARS + " at bp " + currentBP);

            if (TREESEQ_SAVE_KEYPOINTS == 1)
                treeSeqSave("functional_extinction_bp" + currentBP);
        }

        if (STOP_ON_FUNCTIONAL_EXT == 1)
            sim.simulationFinished();
    }

    if (p1.individualCount < QUASI_EXT_N)
    {
        if (!sim.getValue("quasi_extinction_recorded"))
        {
            sim.setValue("quasi_extinction_recorded", T);
            writeEvent("quasi_extinction", "N < QUASI_EXT_N at bp " + currentBP);

            if (TREESEQ_SAVE_KEYPOINTS == 1)
                treeSeqSave("quasi_extinction_bp" + currentBP);
        }
    }

    if (currentBP == END_BP)
    {
        writeEvent("end_forward", "Reached END_BP.");

        if (TREESEQ_SAVE_KEYPOINTS == 1)
            treeSeqSave("bp" + END_BP);

        catn("Finished forward run at BP " + END_BP + ", N = " + p1.individualCount);
        sim.simulationFinished();
    }
}


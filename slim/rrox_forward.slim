// rrox_forward.slim
// 川金丝猴古代局域种群forward模型
// SLiM 5.2, nonWF, 1 tick = 1年
//
// 本脚本从burn-in .trees文件开始，运行一个从5200 BP到0 BP的环境情景。
//
// 环境情景：
//   M1 baseline:  K_t = K5200
//   M2 climate:   K_t = K5200 * climate_K_factor(t)
//   M3 human:     K_t = K5200 * human_K_factor(t)，并叠加q_hunting(t)
//   M4 combined:  K_t = K5200 * climate_K_factor(t) * human_K_factor(t)，并叠加q_hunting(t)
//
// 预期运行方式：
// slim -d RUN_MODE='"forward"' -d SCENARIO='"M4"' -d GENETIC_MODE='"selected"' ...
//
// 主要输入文件：
//   BURNIN_TREES_IN
//   BURNIN_SOCIAL_STATE_IN
//   LIFE_TABLE_FILE:        age annual_mortality
//   CLIMATE_FILE:           bp climate_K_factor
//   HUMAN_FILE:             bp cropland_area cropland_pressure human_K_factor
//   HUNTING_FILE:           bp annual_hunting_mortality

function (void) requireParam(string name)
{
    if (!exists(name))
        stop("ERROR: required parameter is missing: " + name);
}

function (void) validateScalarParams(void)
{
    // 核心参数
    requireParam("RUN_MODE");
    requireParam("SCENARIO");
    requireParam("GENETIC_MODE");
    requireParam("REPLICATE_ID");
    requireParam("RANDOM_SEED");
    requireParam("OUT_PREFIX");
    requireParam("START_BP");
    requireParam("END_BP");
    requireParam("FORWARD_YEARS");
    requireParam("INCLUDE_BP0");
    requireParam("K5200");
    requireParam("STAT_INTERVAL");
    requireParam("GENETIC_STAT_INTERVAL");
    requireParam("GENETIC_STAT_N_LT100_INTERVAL");
    requireParam("SAMPLE_SIZE");
    requireParam("FUNCTIONAL_EXT_YEARS");
    requireParam("STOP_ON_FUNCTIONAL_EXT");
    requireParam("QUASI_EXT_N");
    requireParam("SAVE_TREES");
    requireParam("BURNIN_TREES_IN");
    requireParam("BURNIN_SOCIAL_STATE_IN");
    requireParam("TREESEQ_SAVE_KEYPOINTS");

    // 输入文件
    requireParam("LIFE_TABLE_FILE");
    requireParam("CLIMATE_FILE");
    requireParam("HUMAN_FILE");
    requireParam("HUNTING_FILE");

    // 生活史参数
    requireParam("GENERATION_TIME");
    requireParam("MAX_AGE");
    requireParam("FEMALE_MIN_REP_AGE");
    requireParam("FEMALE_MAX_REP_AGE");
    requireParam("MALE_MIN_REP_AGE");
    requireParam("MALE_MAX_REP_AGE");
    requireParam("DOM_MALE_MIN_AGE");
    requireParam("DOM_MALE_MAX_AGE");
    requireParam("MALE_SENESCENCE_AGE");
    requireParam("MALE_DOMINANCE_BACKUP_MIN_AGE");
    requireParam("MALE_DOMINANCE_BACKUP_MAX_AGE");
    requireParam("MALE_DISPERSAL_AGE");
    requireParam("DEPENDENCE_AGE");
    requireParam("INTERBIRTH_INTERVAL");
    requireParam("INTERBIRTH_IF_INFANT_DIES");
    requireParam("LITTER_SIZE");
    requireParam("USE_P_CONCEPTION");
    requireParam("P_CONCEPTION");
    requireParam("SEX_RATIO_AT_BIRTH");
    requireParam("REQUIRE_NO_DEPENDENT_INFANT");
    requireParam("NEWBORNS_EXPERIENCE_AGE0_MORTALITY");
    requireParam("GENETIC_FITNESS_AFFECTS_SURVIVAL");
    requireParam("GENETIC_FITNESS_AFFECTS_REPRODUCTION");

    // 社会结构参数
    requireParam("SOCIAL_STRUCTURE_MODE");
    requireParam("OMU_FEMALES");
    requireParam("OMU_SPLIT_THRESHOLD");
    requireParam("OMU_SPLIT_FEMALES");
    requireParam("OMU_DISSOLVE_FEMALES");
    requireParam("OMU_STABLE_INHERITANCE");
    requireParam("FEMALE_DISPERSAL");
    requireParam("FEMALE_STAY_NATAL_OMU");
    requireParam("MALE_LEAVE_NATAL_OMU");
    requireParam("AMU_TARGET_SIZE");
    requireParam("AMU_MALES_PER_OMU");
    requireParam("AMU_GROUPING_MODE");
    requireParam("AMU_POOL_RULE");
    requireParam("SOLITARY_MALE_MODE");
    requireParam("SOLITARY_MALES_TO_AMU");
    requireParam("DOM_MALE_ASSIGNMENT_MODE");
    requireParam("DOM_MALE_REPLACEMENT_SOURCE");
    requireParam("DOM_MALE_RETIRE_AT_MAX_AGE");
    requireParam("DOM_MALE_REPLACEMENT_ON_DEATH");
    requireParam("DOM_MALE_BACKUP_ALLOWED");
    requireParam("DOM_MALE_TAKEOVER_MODE");
    requireParam("DOM_MALE_RANDOM_WITHIN_CANDIDATES");
    requireParam("DOM_MALE_RETIRED_TO_AMU");
    requireParam("P_OWN_OMU");
    requireParam("P_OTHER_OMU");
    requireParam("P_AMU");
    requireParam("PATERNITY_WEIGHTS_SUM");
    requireParam("DYNAMIC_PATERNITY_RENORMALIZE");
    requireParam("NO_FATHER_NO_REPRODUCTION");
    requireParam("OWN_OMU_FATHER_RULE");
    requireParam("OTHER_OMU_FATHER_RULE");
    requireParam("AMU_FATHER_RULE");
    requireParam("FATHER_CHOICE_WITHIN_CATEGORY");
    requireParam("INITIAL_OMU_ASSIGNMENT");
    requireParam("INITIAL_DOM_MALE_ASSIGNMENT");
    requireParam("INITIAL_AMU_ASSIGNMENT");
    requireParam("INITIAL_AMU_GROUPING");
    requireParam("ALLOW_OMU_SPLIT");
    requireParam("SPLIT_REQUIRES_DOM_MALE");
    requireParam("ALLOW_OMU_DISSOLUTION");
    requireParam("EMPTY_OMU_INDIVIDUALS_TO_AMU");
    requireParam("USE_KIN_AVOIDANCE");
    requireParam("MAX_CHILD_FPED");

    // 基因组和DFE参数
    requireParam("MU_RATE");
    requireParam("CHROM_COUNT");
    requireParam("GENE_COUNT");
    requireParam("GENE_LENGTH");
    requireParam("NEUTRAL_FRACTION");
    requireParam("DELETERIOUS_FRACTION");
    requireParam("DFE_MEAN");
    requireParam("DFE_SHAPE");
    requireParam("INTERGENIC_RECOMB_RATE");

    if (RUN_MODE != "forward")
        stop("ERROR: rrox_forward.slim requires RUN_MODE = forward.");

    if (!((SCENARIO == "M1") | (SCENARIO == "M2") | (SCENARIO == "M3") | (SCENARIO == "M4")))
        stop("ERROR: SCENARIO must be M1, M2, M3, or M4.");

    if (!((GENETIC_MODE == "selected") | (GENETIC_MODE == "neutral")))
        stop("ERROR: GENETIC_MODE must be selected or neutral.");

    if (START_BP <= END_BP)
        stop("ERROR: START_BP must be larger than END_BP.");

    if (FORWARD_YEARS != (START_BP - END_BP))
        stop("ERROR: FORWARD_YEARS must equal START_BP - END_BP.");

    if (INCLUDE_BP0 != 1)
        stop("ERROR: this script expects INCLUDE_BP0 = 1, so 5200..0 BP has 5201 ticks.");

    if (K5200 <= 0)
        stop("ERROR: K5200 must be > 0.");

    if (STAT_INTERVAL < 1)
        stop("ERROR: STAT_INTERVAL must be >= 1.");

    if (GENETIC_STAT_INTERVAL < 1)
        stop("ERROR: GENETIC_STAT_INTERVAL must be >= 1.");

    if (GENETIC_STAT_N_LT100_INTERVAL < 1)
        stop("ERROR: GENETIC_STAT_N_LT100_INTERVAL must be >= 1.");

    if (SAMPLE_SIZE < 1)
        stop("ERROR: SAMPLE_SIZE must be >= 1.");

    if (FUNCTIONAL_EXT_YEARS < 1)
        stop("ERROR: FUNCTIONAL_EXT_YEARS must be >= 1.");

    if (QUASI_EXT_N < 1)
        stop("ERROR: QUASI_EXT_N must be >= 1.");

    if (GENERATION_TIME <= 0)
        stop("ERROR: GENERATION_TIME must be > 0.");

    if (MAX_AGE < 1)
        stop("ERROR: MAX_AGE must be >= 1.");

    if (FEMALE_MIN_REP_AGE < 0 | FEMALE_MAX_REP_AGE < FEMALE_MIN_REP_AGE)
        stop("ERROR: invalid female reproductive age range.");

    if (MALE_MIN_REP_AGE < 0 | MALE_MAX_REP_AGE < MALE_MIN_REP_AGE)
        stop("ERROR: invalid male reproductive age range.");

    if (DOM_MALE_MAX_AGE < DOM_MALE_MIN_AGE)
        stop("ERROR: invalid dominant male age range.");

    if (MALE_DOMINANCE_BACKUP_MAX_AGE < MALE_DOMINANCE_BACKUP_MIN_AGE)
        stop("ERROR: invalid backup dominant male age range.");

    if (USE_P_CONCEPTION != 0 & USE_P_CONCEPTION != 1)
        stop("ERROR: USE_P_CONCEPTION must be 0 or 1.");

    if (P_CONCEPTION < 0.0 | P_CONCEPTION > 1.0)
        stop("ERROR: P_CONCEPTION must be in [0,1].");

    if (GENETIC_FITNESS_AFFECTS_SURVIVAL != 1)
        stop("ERROR: main model expects GENETIC_FITNESS_AFFECTS_SURVIVAL = 1.");

    if (GENETIC_FITNESS_AFFECTS_REPRODUCTION != 0)
        stop("ERROR: main model expects GENETIC_FITNESS_AFFECTS_REPRODUCTION = 0.");

    if (OMU_FEMALES < 1)
        stop("ERROR: OMU_FEMALES must be >= 1.");

    if (OMU_SPLIT_THRESHOLD <= OMU_FEMALES)
        stop("ERROR: OMU_SPLIT_THRESHOLD should be larger than OMU_FEMALES.");

    if (OMU_DISSOLVE_FEMALES < 0)
        stop("ERROR: OMU_DISSOLVE_FEMALES must be >= 0.");

    if (AMU_TARGET_SIZE < 1)
        stop("ERROR: AMU_TARGET_SIZE must be >= 1.");

    if (AMU_MALES_PER_OMU < 0.0)
        stop("ERROR: AMU_MALES_PER_OMU must be >= 0.");

    if (SOCIAL_STRUCTURE_MODE != "explicit_OMU_AMU")
        stop("ERROR: only SOCIAL_STRUCTURE_MODE = explicit_OMU_AMU is implemented.");

    if (OMU_STABLE_INHERITANCE != 1)
        stop("ERROR: this model implements stable OMU inheritance; set OMU_STABLE_INHERITANCE = 1.");

    if (FEMALE_DISPERSAL != 0 | FEMALE_STAY_NATAL_OMU != 1)
        stop("ERROR: this model expects FEMALE_DISPERSAL = 0 and FEMALE_STAY_NATAL_OMU = 1.");

    if (MALE_LEAVE_NATAL_OMU != 0 & MALE_LEAVE_NATAL_OMU != 1)
        stop("ERROR: MALE_LEAVE_NATAL_OMU must be 0 or 1.");

    if (AMU_GROUPING_MODE != "by_target_size" | INITIAL_AMU_GROUPING != "by_AMU_TARGET_SIZE")
        stop("ERROR: only AMU grouping by target size is supported.");

    if (AMU_POOL_RULE != "remaining_males" | INITIAL_AMU_ASSIGNMENT != "remaining_males")
        stop("ERROR: this model expects remaining males to enter AMU.");

    if (SOLITARY_MALE_MODE != "none" | SOLITARY_MALES_TO_AMU != 1)
        stop("ERROR: solitary males are not modeled separately; set SOLITARY_MALE_MODE = none and SOLITARY_MALES_TO_AMU = 1.");

    if (DOM_MALE_ASSIGNMENT_MODE != "age_priority_random" | INITIAL_DOM_MALE_ASSIGNMENT != "age_priority_random")
        stop("ERROR: only age_priority_random dominant male assignment is implemented.");

    if (DOM_MALE_REPLACEMENT_SOURCE != "AMU")
        stop("ERROR: only DOM_MALE_REPLACEMENT_SOURCE = AMU is implemented.");

    if (DOM_MALE_RETIRE_AT_MAX_AGE != 0 & DOM_MALE_RETIRE_AT_MAX_AGE != 1)
        stop("ERROR: DOM_MALE_RETIRE_AT_MAX_AGE must be 0 or 1.");

    if (DOM_MALE_REPLACEMENT_ON_DEATH != 0 & DOM_MALE_REPLACEMENT_ON_DEATH != 1)
        stop("ERROR: DOM_MALE_REPLACEMENT_ON_DEATH must be 0 or 1.");

    if (DOM_MALE_BACKUP_ALLOWED != 0 & DOM_MALE_BACKUP_ALLOWED != 1)
        stop("ERROR: DOM_MALE_BACKUP_ALLOWED must be 0 or 1.");

    if (DOM_MALE_TAKEOVER_MODE != "vacancy_only")
        stop("ERROR: only DOM_MALE_TAKEOVER_MODE = vacancy_only is implemented.");

    if (DOM_MALE_RANDOM_WITHIN_CANDIDATES != 0 & DOM_MALE_RANDOM_WITHIN_CANDIDATES != 1)
        stop("ERROR: DOM_MALE_RANDOM_WITHIN_CANDIDATES must be 0 or 1.");

    if (DOM_MALE_RETIRED_TO_AMU != 1)
        stop("ERROR: this model expects retired dominant males to return to AMU.");

    if (OWN_OMU_FATHER_RULE != "dominant_male_only")
        stop("ERROR: only OWN_OMU_FATHER_RULE = dominant_male_only is implemented.");

    if (OTHER_OMU_FATHER_RULE != "dominant_males_only")
        stop("ERROR: only OTHER_OMU_FATHER_RULE = dominant_males_only is implemented.");

    if (AMU_FATHER_RULE != "reproductive_age_AMU_male")
        stop("ERROR: only AMU_FATHER_RULE = reproductive_age_AMU_male is implemented.");

    if (FATHER_CHOICE_WITHIN_CATEGORY != "random")
        stop("ERROR: only random father choice within category is implemented.");

    if (INITIAL_OMU_ASSIGNMENT != "adult_females_by_OMU_SIZE")
        stop("ERROR: only INITIAL_OMU_ASSIGNMENT = adult_females_by_OMU_SIZE is implemented.");

    if (ALLOW_OMU_SPLIT != 0 & ALLOW_OMU_SPLIT != 1)
        stop("ERROR: ALLOW_OMU_SPLIT must be 0 or 1.");

    if (SPLIT_REQUIRES_DOM_MALE != 0 & SPLIT_REQUIRES_DOM_MALE != 1)
        stop("ERROR: SPLIT_REQUIRES_DOM_MALE must be 0 or 1.");

    if (ALLOW_OMU_DISSOLUTION != 0 & ALLOW_OMU_DISSOLUTION != 1)
        stop("ERROR: ALLOW_OMU_DISSOLUTION must be 0 or 1.");

    if (EMPTY_OMU_INDIVIDUALS_TO_AMU != 0 & EMPTY_OMU_INDIVIDUALS_TO_AMU != 1)
        stop("ERROR: EMPTY_OMU_INDIVIDUALS_TO_AMU must be 0 or 1.");

    if (USE_KIN_AVOIDANCE != 0)
        stop("ERROR: USE_KIN_AVOIDANCE is not implemented in this model; set it to 0.");

    if (abs((P_OWN_OMU + P_OTHER_OMU + P_AMU) - PATERNITY_WEIGHTS_SUM) > 1e-8)
        stop("ERROR: P_OWN_OMU + P_OTHER_OMU + P_AMU must equal PATERNITY_WEIGHTS_SUM.");

    if (MU_RATE < 0)
        stop("ERROR: MU_RATE must be >= 0.");

    if (CHROM_COUNT < 1)
        stop("ERROR: CHROM_COUNT must be >= 1.");

    if (GENE_COUNT < CHROM_COUNT)
        stop("ERROR: GENE_COUNT should be >= CHROM_COUNT.");

    if (GENE_LENGTH < 2)
        stop("ERROR: GENE_LENGTH must be >= 2.");

    if (NEUTRAL_FRACTION < 0 | DELETERIOUS_FRACTION < 0)
        stop("ERROR: mutation fractions must be >= 0.");

    if (abs((NEUTRAL_FRACTION + DELETERIOUS_FRACTION) - 1.0) > 1e-8)
        stop("ERROR: NEUTRAL_FRACTION + DELETERIOUS_FRACTION must equal 1.");

    if (DFE_MEAN >= 0)
        stop("ERROR: DFE_MEAN must be negative for deleterious mutations.");

    if (DFE_SHAPE <= 0)
        stop("ERROR: DFE_SHAPE must be > 0.");

    if (INTERGENIC_RECOMB_RATE < 0 | INTERGENIC_RECOMB_RATE > 0.5)
        stop("ERROR: INTERGENIC_RECOMB_RATE must be in [0, 0.5].");
}

function (void) initializeRecombinationMapFromCompressedGenome(void)
{
    rates = c();
    ends = c();

    baseGenes = asInteger(floor(GENE_COUNT / CHROM_COUNT));
    extraGenes = GENE_COUNT - baseGenes * CHROM_COUNT;

    pos = 0;

    for (chr in 0:(CHROM_COUNT - 1))
    {
        genesOnChr = baseGenes;
        if (chr < extraGenes)
            genesOnChr = genesOnChr + 1;

        for (g in 0:(genesOnChr - 1))
        {
            geneStart = pos;
            geneEnd = geneStart + GENE_LENGTH - 1;

            // 每个压缩基因内部不发生重组。
            rates = c(rates, 0.0);
            ends = c(ends, geneEnd - 1);

            // 相邻基因之间发生重组；染色体边界处近似为染色体间自由重组。
            if (g < (genesOnChr - 1))
            {
                rates = c(rates, INTERGENIC_RECOMB_RATE);
                ends = c(ends, geneEnd);
            }
            else
            {
                if (chr < (CHROM_COUNT - 1))
                {
                    rates = c(rates, 0.5);
                    ends = c(ends, geneEnd);
                }
                else
                {
                    rates = c(rates, 0.0);
                    ends = c(ends, geneEnd);
                }
            }

            pos = geneEnd + 1;
        }
    }

    expectedLength = GENE_COUNT * GENE_LENGTH;
    if (pos != expectedLength)
        stop("ERROR: compressed genome length mismatch.");

    defineConstant("GENOME_LENGTH", expectedLength);
    initializeRecombinationRate(rates, ends);
}

function (float) readLifeTableMortality(string path, integer maxAge)
{
    lines = readFile(path);

    if (size(lines) < 2)
        stop("ERROR: LIFE_TABLE_FILE contains no data rows: " + path);

    header = strsplit(lines[0], "\t");

    if (size(header) < 2)
        stop("ERROR: LIFE_TABLE_FILE header must contain age and annual_mortality.");

    if (header[0] != "age" | header[1] != "annual_mortality")
        stop("ERROR: LIFE_TABLE_FILE header must be: age<TAB>annual_mortality.");

    mort = rep(-1.0, maxAge + 1);

    for (i in 1:(size(lines) - 1))
    {
        if (lines[i] == "")
            next;

        fields = strsplit(lines[i], "\t");
        if (size(fields) < 2)
            stop("ERROR: bad life table row: " + lines[i]);

        age = asInteger(fields[0]);
        q = asFloat(fields[1]);

        if (age < 0 | age > maxAge)
            stop("ERROR: life table age outside 0..MAX_AGE: " + age);

        if (q < 0.0 | q > 1.0)
            stop("ERROR: annual_mortality must be in [0,1] at age " + age);

        mort[age] = q;
    }

    for (a in 0:maxAge)
    {
        if (mort[a] < 0.0)
            stop("ERROR: LIFE_TABLE_FILE missing age: " + a);
    }

    return mort;
}

function (float) readClimateFactor(string path)
{
    lines = readFile(path);
    if (size(lines) < 2)
        stop("ERROR: CLIMATE_FILE contains no data rows: " + path);

    header = strsplit(lines[0], "\t");
    if (size(header) < 2)
        stop("ERROR: CLIMATE_FILE header must be bp and climate_K_factor.");

    if (header[0] != "bp" | header[1] != "climate_K_factor")
        stop("ERROR: CLIMATE_FILE header must be: bp<TAB>climate_K_factor.");

    values = rep(-1.0, START_BP + 1);

    for (i in 1:(size(lines) - 1))
    {
        if (lines[i] == "")
            next;

        fields = strsplit(lines[i], "\t");
        if (size(fields) < 2)
            stop("ERROR: bad climate row: " + lines[i]);

        bp = asInteger(fields[0]);
        f = asFloat(fields[1]);

        if (bp < END_BP | bp > START_BP)
            stop("ERROR: CLIMATE_FILE bp outside simulated interval: " + bp);

        if (f <= 0.0 | f > 1.0)
            stop("ERROR: climate_K_factor must be in (0,1] at bp " + bp);

        if (values[bp] >= 0.0)
            stop("ERROR: duplicated bp in CLIMATE_FILE: " + bp);

        values[bp] = f;
    }

    for (bp in END_BP:START_BP)
    {
        if (values[bp] < 0.0)
            stop("ERROR: CLIMATE_FILE missing bp: " + bp);
    }

    return values;
}

function (float) readHumanFactor(string path)
{
    lines = readFile(path);
    if (size(lines) < 2)
        stop("ERROR: HUMAN_FILE contains no data rows: " + path);

    header = strsplit(lines[0], "\t");
    if (size(header) < 4)
        stop("ERROR: HUMAN_FILE header must contain bp, cropland_area, cropland_pressure, human_K_factor.");

    if (header[0] != "bp" | header[1] != "cropland_area" |
        header[2] != "cropland_pressure" | header[3] != "human_K_factor")
        stop("ERROR: HUMAN_FILE header must be: bp<TAB>cropland_area<TAB>cropland_pressure<TAB>human_K_factor.");

    values = rep(-1.0, START_BP + 1);

    for (i in 1:(size(lines) - 1))
    {
        if (lines[i] == "")
            next;

        fields = strsplit(lines[i], "\t");
        if (size(fields) < 4)
            stop("ERROR: bad human_K row: " + lines[i]);

        bp = asInteger(fields[0]);
        cropland = asFloat(fields[1]);
        pressure = asFloat(fields[2]);
        f = asFloat(fields[3]);

        if (bp < END_BP | bp > START_BP)
            stop("ERROR: HUMAN_FILE bp outside simulated interval: " + bp);

        if (cropland < 0.0)
            stop("ERROR: cropland_area must be >= 0 at bp " + bp);

        if (pressure < 0.0 | pressure > 1.0)
            stop("ERROR: cropland_pressure must be in [0,1] at bp " + bp);

        if (f <= 0.0 | f > 1.0)
            stop("ERROR: human_K_factor must be in (0,1] at bp " + bp);

        if (values[bp] >= 0.0)
            stop("ERROR: duplicated bp in HUMAN_FILE: " + bp);

        values[bp] = f;
    }

    for (bp in END_BP:START_BP)
    {
        if (values[bp] < 0.0)
            stop("ERROR: HUMAN_FILE missing bp: " + bp);
    }

    return values;
}

function (float) readHuntingMortality(string path)
{
    lines = readFile(path);
    if (size(lines) < 2)
        stop("ERROR: HUNTING_FILE contains no data rows: " + path);

    header = strsplit(lines[0], "\t");
    if (size(header) < 2)
        stop("ERROR: HUNTING_FILE header must contain bp and annual_hunting_mortality.");

    if (header[0] != "bp" | header[1] != "annual_hunting_mortality")
        stop("ERROR: HUNTING_FILE header must be: bp<TAB>annual_hunting_mortality.");

    values = rep(-1.0, START_BP + 1);

    for (i in 1:(size(lines) - 1))
    {
        if (lines[i] == "")
            next;

        fields = strsplit(lines[i], "\t");
        if (size(fields) < 2)
            stop("ERROR: bad hunting row: " + lines[i]);

        bp = asInteger(fields[0]);
        q = asFloat(fields[1]);

        if (bp < END_BP | bp > START_BP)
            stop("ERROR: HUNTING_FILE bp outside simulated interval: " + bp);

        if (q < 0.0 | q >= 1.0)
            stop("ERROR: annual_hunting_mortality must be in [0,1) at bp " + bp);

        if (values[bp] >= 0.0)
            stop("ERROR: duplicated bp in HUNTING_FILE: " + bp);

        values[bp] = q;
    }

    for (bp in END_BP:START_BP)
    {
        if (values[bp] < 0.0)
            stop("ERROR: HUNTING_FILE missing bp: " + bp);
    }

    return values;
}

function (integer) getCurrentBP(void)
{
    startCycle = sim.getValue("forward_start_cycle");
    bp = asInteger(START_BP - (sim.cycle - startCycle));

    if (bp < END_BP | bp > START_BP)
        stop("ERROR: currentBP outside simulated interval: " + bp);

    return bp;
}

function (void) updateEnvironmentForCurrentBP(void)
{
    currentBP = getCurrentBP();

    climateFactor = 1.0;
    humanFactor = 1.0;
    huntingQ = 0.0;

    if (SCENARIO == "M2" | SCENARIO == "M4")
        climateFactor = sim.getValue("climate_factor")[currentBP];

    if (SCENARIO == "M3" | SCENARIO == "M4")
    {
        humanFactor = sim.getValue("human_factor")[currentBP];
        huntingQ = sim.getValue("hunting_q")[currentBP];
    }

    Kt = K5200 * climateFactor * humanFactor;

    if (Kt < 0.0)
        stop("ERROR: K_t must not be negative.");

    sim.setValue("currentBP", currentBP);
    sim.setValue("climate_factor_t", climateFactor);
    sim.setValue("human_factor_t", humanFactor);
    sim.setValue("hunting_q_t", huntingQ);
    sim.setValue("K_t", Kt);
}

function (void) initializeOutputFiles(void)
{
    demoFile = OUT_PREFIX + ".forward_demography.tsv";
    demoHeader = "cycle\tbp\tstage\tscenario\tgenetic_mode\tN\tK_t\tclimate_K_factor\thuman_K_factor\tq_hunting\tN_female\tN_male\tN_juvenile\tN_age0\tN_age1\tbirths_total\tbirths_own_OMU\tbirths_other_OMU\tbirths_AMU\tadult_females\tadult_males\tbreeding_females\tcandidate_fathers\tOMU_count\tAMU_males\tAMU_count_proxy\tAMU_males_per_OMU\tdominant_males\tno_breeder_years\tquasi_extinct\tfunctional_extinct\tdemographic_extinct\tmean_age\tdensity_factor";
    writeFile(demoFile, demoHeader, append=F);
    sim.setValue("demo_file", demoFile);

    genFile = OUT_PREFIX + ".forward_genetic.tsv";
    genHeader = "cycle\tbp\tscenario\tgenetic_mode\tN\tsample_n\tmean_genetic_fitness\tmean_2B\tmean_het_del\tmean_hom_del\tmean_weak_het\tmean_moderate_het\tmean_strong_het\tmean_vstrong_het\tsegregating_del_muts\tfixed_del_muts";
    writeFile(genFile, genHeader, append=F);
    sim.setValue("gen_file", genFile);

    eventFile = OUT_PREFIX + ".forward_events.tsv";
    eventHeader = "cycle\tbp\tevent\tN\tmessage";
    writeFile(eventFile, eventHeader, append=F);
    sim.setValue("event_file", eventFile);

    qaFile = OUT_PREFIX + ".forward_age_social_QA.tsv";
    qaHeader = "cycle\tbp\tscenario\tgenetic_mode\tstage\tN\tage_0_1\tage_2_4\tage_5_9\tage_10_14\tage_15_19\tage_20_28\tOMU_count\tdominant_males\tdominant_candidate_males\tbackup_candidate_males\tAMU_dominant_candidate_males\tAMU_backup_candidate_males\tvacant_OMU_count\tinvalid_dominant_males\tduplicate_dominant_males";
    writeFile(qaFile, qaHeader, append=F);
    sim.setValue("forward_qa_file", qaFile);
}

function (void) writeEvent(string eventName, string message)
{
    bp = sim.getValue("currentBP");
    line = sim.cycle + "\t" + bp + "\t" + eventName + "\t" + p1.individualCount + "\t" + message;
    writeFile(sim.getValue("event_file"), line, append=T);
}

function (logical) shouldWriteForwardStats(void)
{
    currentBP = sim.getValue("currentBP");
    return (((sim.cycle - sim.getValue("forward_start_cycle")) % STAT_INTERVAL == 0) |
            currentBP == END_BP |
            p1.individualCount == 0);
}

function (void) resetBirthCounters(void)
{
    sim.setValue("births_total", 0);
    sim.setValue("births_own_OMU", 0);
    sim.setValue("births_other_OMU", 0);
    sim.setValue("births_AMU", 0);
    sim.setValue("last_father_category", "none");
}

function (void) incrementBirthCounter(string category)
{
    sim.setValue("births_total", sim.getValue("births_total") + 1);

    if (category == "own_OMU")
        sim.setValue("births_own_OMU", sim.getValue("births_own_OMU") + 1);
    else
    {
        if (category == "other_OMU")
            sim.setValue("births_other_OMU", sim.getValue("births_other_OMU") + 1);
        else
        {
            if (category == "AMU")
                sim.setValue("births_AMU", sim.getValue("births_AMU") + 1);
        }
    }
}

function (void) writeForwardQALog(string stage)
{
    inds = p1.individuals;
    N = size(inds);
    bp = sim.getValue("currentBP");

    if (N == 0)
    {
        line = sim.cycle + "\t" + bp + "\t" + SCENARIO + "\t" + GENETIC_MODE +
               "\t" + stage + "\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0\t0";
        writeFile(sim.getValue("forward_qa_file"), line, append=T);
        return;
    }

    males = inds[inds.sex == "M"];
    adultFemales = inds[(inds.sex == "F") &
                        (inds.age >= FEMALE_MIN_REP_AGE) &
                        (inds.age <= FEMALE_MAX_REP_AGE)];

    age_0_1 = inds[(inds.age >= 0) & (inds.age <= 1)];
    age_2_4 = inds[(inds.age >= 2) & (inds.age <= 4)];
    age_5_9 = inds[(inds.age >= 5) & (inds.age <= 9)];
    age_10_14 = inds[(inds.age >= 10) & (inds.age <= 14)];
    age_15_19 = inds[(inds.age >= 15) & (inds.age <= 19)];
    age_20_28 = inds[(inds.age >= 20) & (inds.age <= 28)];

    omuIds = getReproductiveOMUIds();

    dominantMaleCount = countDominantMalesInReproductiveOMUs();
    dominantCandidateMales = males[(males.age >= DOM_MALE_MIN_AGE) &
                                   (males.age <= DOM_MALE_MAX_AGE)];
    backupCandidateMales = males[(males.age >= MALE_DOMINANCE_BACKUP_MIN_AGE) &
                                 (males.age <= MALE_DOMINANCE_BACKUP_MAX_AGE)];
    amuDominantCandidateMales = dominantCandidateMales[dominantCandidateMales.tag == 0];
    amuBackupCandidateMales = backupCandidateMales[backupCandidateMales.tag == 0];
    vacantOMUCount = countVacantReproductiveOMUs();
    invalidDominantMales = countInvalidDominantMales();
    duplicateDominantMales = countDuplicateDominantMales();

    line = sim.cycle + "\t" +
           bp + "\t" +
           SCENARIO + "\t" +
           GENETIC_MODE + "\t" +
           stage + "\t" +
           N + "\t" +
           size(age_0_1) + "\t" +
           size(age_2_4) + "\t" +
           size(age_5_9) + "\t" +
           size(age_10_14) + "\t" +
           size(age_15_19) + "\t" +
           size(age_20_28) + "\t" +
           size(omuIds) + "\t" +
           dominantMaleCount + "\t" +
           size(dominantCandidateMales) + "\t" +
           size(backupCandidateMales) + "\t" +
           size(amuDominantCandidateMales) + "\t" +
           size(amuBackupCandidateMales) + "\t" +
           vacantOMUCount + "\t" +
           invalidDominantMales + "\t" +
           duplicateDominantMales;

    writeFile(sim.getValue("forward_qa_file"), line, append=T);
}

function (void) treeSeqSave(string label)
{
    if (SAVE_TREES != 1)
        return;

    out = OUT_PREFIX + "." + label + ".trees";
    sim.treeSeqOutput(out);
    writeEvent("treeSeqOutput", out);
}

function (void) resetNewAdultFemaleTags(void)
{
    females = p1.individuals[p1.individuals.sex == "F"];

    // 雌性未成年个体可能在tagF中携带母亲pedigreeID。
    // 一旦成为成年雌性，tagF重置为上次繁殖cycle存储位。
    newAdultFemales = females[(females.age >= FEMALE_MIN_REP_AGE) &
                              (females.tagF < 0.0)];

    if (size(newAdultFemales) > 0)
        newAdultFemales.tagF = -999999.0;
}

function (integer) getNextOMUId(void)
{
    id = sim.getValue("next_omu_id");
    sim.setValue("next_omu_id", id + 1);
    return id;
}

function (object) chooseDominantCandidate(object candidates)
{
    if (size(candidates) == 0)
        return NULL;

    if (DOM_MALE_RANDOM_WITHIN_CANDIDATES == 1)
        return sample(candidates, 1);

    return candidates[0];
}

function (float) motherTagF(object female)
{
    return -1.0 * (asFloat(female.pedigreeID) + 1.0);
}

function (object) getReproductiveFemales(void)
{
    inds = p1.individuals;
    return inds[(inds.sex == "F") &
                (inds.age >= FEMALE_MIN_REP_AGE) &
                (inds.age <= FEMALE_MAX_REP_AGE) &
                (inds.tag > 0)];
}

function (integer) getReproductiveOMUIds(void)
{
    females = getReproductiveFemales();

    if (size(females) == 0)
        return integer(0);

    ids = sort(unique(females.tag));
    return ids[ids > 0];
}

function (integer) countDominantMalesInReproductiveOMUs(void)
{
    inds = p1.individuals;
    males = inds[inds.sex == "M"];
    omuIds = getReproductiveOMUIds();

    if (size(omuIds) == 0)
        return 0;

    n = 0;
    for (omuId in omuIds)
        n = n + size(males[(males.tag == omuId) & (males.tagF == 1.0)]);

    return n;
}

function (integer) countVacantReproductiveOMUs(void)
{
    inds = p1.individuals;
    males = inds[inds.sex == "M"];
    omuIds = getReproductiveOMUIds();

    if (size(omuIds) == 0)
        return 0;

    n = 0;
    for (omuId in omuIds)
    {
        current = males[(males.tag == omuId) & (males.tagF == 1.0)];
        if (size(current) == 0)
            n = n + 1;
    }

    return n;
}

function (integer) countInvalidDominantMales(void)
{
    inds = p1.individuals;
    males = inds[inds.sex == "M"];
    dominants = males[(males.tag > 0) & (males.tagF == 1.0)];
    omuIds = getReproductiveOMUIds();

    if (size(dominants) == 0)
        return 0;

    if (size(omuIds) == 0)
        return size(dominants);

    n = 0;
    for (dom in dominants)
    {
        if (!any(omuIds == dom.tag))
            n = n + 1;
    }

    return n;
}

function (integer) countDuplicateDominantMales(void)
{
    inds = p1.individuals;
    males = inds[inds.sex == "M"];
    omuIds = getReproductiveOMUIds();

    if (size(omuIds) == 0)
        return 0;

    n = 0;
    for (omuId in omuIds)
    {
        current = males[(males.tag == omuId) & (males.tagF == 1.0)];
        if (size(current) > 1)
            n = n + size(current) - 1;
    }

    return n;
}

function (void) readBurninSocialState(string path)
{
    lines = readFile(path);

    if (size(lines) < 1)
        stop("ERROR: BURNIN_SOCIAL_STATE_IN is empty: " + path);

    header = strsplit(lines[0], "\t");
    if (size(header) < 5)
        stop("ERROR: BURNIN_SOCIAL_STATE_IN header must contain pedigreeID, sex, age, omu_id, tagF.");

    if (header[0] != "pedigreeID" | header[1] != "sex" | header[2] != "age" |
        header[3] != "omu_id" | header[4] != "tagF")
        stop("ERROR: BURNIN_SOCIAL_STATE_IN header must be: pedigreeID<TAB>sex<TAB>age<TAB>omu_id<TAB>tagF.");

    inds = p1.individuals;
    matchedPedigreeIds = integer(0);

    if (size(lines) > 1)
    {
        for (i in 1:(size(lines) - 1))
        {
            if (lines[i] == "")
                next;

            fields = strsplit(lines[i], "\t");
            if (size(fields) < 5)
                stop("ERROR: bad social state row: " + lines[i]);

            pedigreeID = asInteger(fields[0]);
            sex = fields[1];
            age = asInteger(fields[2]);
            omuId = asInteger(fields[3]);
            tagFValue = asFloat(fields[4]);

            if (size(matchedPedigreeIds[matchedPedigreeIds == pedigreeID]) > 0)
                stop("ERROR: duplicate pedigreeID in BURNIN_SOCIAL_STATE_IN: " + pedigreeID);

            match = inds[inds.pedigreeID == pedigreeID];
            if (size(match) != 1)
                stop("ERROR: social_state pedigreeID not found exactly once in loaded .trees: " + pedigreeID);

            if (match.sex != sex)
                stop("ERROR: social_state sex mismatch for pedigreeID " + pedigreeID);

            if (match.age != age)
                stop("ERROR: social_state age mismatch for pedigreeID " + pedigreeID);

            match.tag = omuId;
            match.tagF = tagFValue;
            matchedPedigreeIds = c(matchedPedigreeIds, pedigreeID);
        }
    }

    for (ind in inds)
    {
        if (size(matchedPedigreeIds[matchedPedigreeIds == ind.pedigreeID]) != 1)
            stop("ERROR: loaded .trees individual missing from BURNIN_SOCIAL_STATE_IN: " + ind.pedigreeID);
    }
}

function (void) assignInitialSocialStructureFromLoadedTree(void)
{
    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    // 关键原则：forward读入burn-in .trees后，不再无条件清空tag/tagF。
    // 新版burn-in会把OMU id、主雄标记、幼体母亲标记和雌性last_birth cycle
    // 存在individual.tag/tagF中；这些信息必须保留，否则第一年会出现所有成年雌性
    // 同步可繁殖的假象。
    females = inds[inds.sex == "F"];
    males = inds[inds.sex == "M"];

    reproductiveTaggedFemales = females[(females.age >= FEMALE_MIN_REP_AGE) &
                                        (females.age <= FEMALE_MAX_REP_AGE) &
                                        (females.tag > 0)];

    // 兼容旧版或损坏的burn-in .trees：如果没有任何带OMU标记的繁殖年龄雌性，
    // 才重建社会结构。这个fallback不能恢复母婴依赖和last_birth信息，因此只用于
    // 旧测试文件；正式分析必须重新生成新版burn-in .trees。
    if (size(reproductiveTaggedFemales) == 0)
    {
        catn("WARNING: loaded .trees contains no tagged reproductive females; rebuilding social structure. Regenerate burn-in .trees for formal runs.");

        inds.tag = 0;
        inds.tagF = 0.0;

        adultFemales = females[(females.age >= FEMALE_MIN_REP_AGE) &
                               (females.age <= FEMALE_MAX_REP_AGE)];

        if (size(adultFemales) == 0)
        {
            omuId = getNextOMUId();
            females.tag = omuId;
            females.tagF = -999999.0;
        }
        else
        {
            adultFemales = sample(adultFemales, size(adultFemales), replace=F);
            nOMU = asInteger(ceil(size(adultFemales) / OMU_FEMALES));

            for (i in 0:(nOMU - 1))
            {
                omuId = getNextOMUId();
                start = i * OMU_FEMALES;
                end = min(c(start + OMU_FEMALES - 1, size(adultFemales) - 1));
                group = adultFemales[start:end];
                group.tag = omuId;
                group.tagF = -999999.0;
            }

            omuIds = sort(unique(adultFemales.tag));
            juvenileFemales = females[females.age < FEMALE_MIN_REP_AGE];
            if (size(juvenileFemales) > 0)
            {
                juvenileFemales.tag = sample(omuIds, size(juvenileFemales), replace=T);
                juvenileFemales.tagF = -999999.0;
            }
        }

        omuIdsAll = sort(unique(females.tag));
        omuIdsAll = omuIdsAll[omuIdsAll > 0];

        maleJuveniles = males[males.age < MALE_DISPERSAL_AGE];
        if (size(maleJuveniles) > 0 & size(omuIdsAll) > 0)
        {
            maleJuveniles.tag = sample(omuIdsAll, size(maleJuveniles), replace=T);
            maleJuveniles.tagF = 0.0;
        }

        amuMales = males[males.age >= MALE_DISPERSAL_AGE];
        if (size(amuMales) > 0)
        {
            amuMales.tag = 0;
            amuMales.tagF = 0.0;
        }

        cleanupDominantMales();
        replaceDominantMales();
        return;
    }

    // 正常路径：保留burn-in携带的社会结构，只做最小清理。
    omuIds = sort(unique(reproductiveTaggedFemales.tag));
    omuIds = omuIds[omuIds > 0];

    // 少数无OMU雌性分配到现有有效繁殖OMU；不清空已有母婴/last_birth信息。
    unassignedFemales = females[females.tag <= 0];
    if (size(unassignedFemales) > 0 & size(omuIds) > 0)
    {
        unassignedFemales.tag = sample(omuIds, size(unassignedFemales), replace=T);
        adultUnassigned = unassignedFemales[unassignedFemales.age >= FEMALE_MIN_REP_AGE];
        if (size(adultUnassigned) > 0)
            adultUnassigned.tagF = -999999.0;
    }

    // 雄性未达到迁出年龄时应保留在OMU；若没有OMU则随机分入有效OMU。
    maleJuveniles = males[(males.age < MALE_DISPERSAL_AGE) & (males.tag <= 0)];
    if (size(maleJuveniles) > 0 & size(omuIds) > 0)
    {
        maleJuveniles.tag = sample(omuIds, size(maleJuveniles), replace=T);
        maleJuveniles.tagF = 0.0;
    }

    // 达到迁出年龄且不是主雄的雄性进入AMU池。
    nonDomDispersedMales = males[(males.age >= MALE_DISPERSAL_AGE) &
                                 (males.tagF != 1.0)];
    if (size(nonDomDispersedMales) > 0)
    {
        nonDomDispersedMales.tag = 0;
        nonDomDispersedMales.tagF = 0.0;
    }

    resetNewAdultFemaleTags();
    cleanupDominantMales();
    replaceDominantMales();
}

function (void) retireOldDominantMales(void)
{
    if (DOM_MALE_RETIRE_AT_MAX_AGE == 0)
        return;

    males = p1.individuals[p1.individuals.sex == "M"];

    oldDominants = males[(males.tag > 0) &
                         (males.tagF == 1.0) &
                         (males.age > DOM_MALE_MAX_AGE)];

    if (size(oldDominants) > 0)
    {
        oldDominants.tag = 0;
        oldDominants.tagF = 0.0;
    }
}

function (void) disperseMales(void)
{
    if (MALE_LEAVE_NATAL_OMU == 0)
        return;

    males = p1.individuals[p1.individuals.sex == "M"];

    dispersers = males[(males.age >= MALE_DISPERSAL_AGE) &
                       (males.tag > 0) &
                       (males.tagF != 1.0)];

    if (size(dispersers) > 0)
    {
        dispersers.tag = 0;
        dispersers.tagF = 0.0;
    }
}

function (void) cleanupDominantMales(void)
{
    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    males = inds[inds.sex == "M"];
    if (size(males) == 0)
        return;

    omuIds = getReproductiveOMUIds();
    dominants = males[(males.tag > 0) & (males.tagF == 1.0)];

    if (size(dominants) == 0)
        return;

    if (size(omuIds) == 0)
    {
        dominants.tag = 0;
        dominants.tagF = 0.0;
        return;
    }

    for (dom in dominants)
    {
        if (!any(omuIds == dom.tag))
        {
            dom.tag = 0;
            dom.tagF = 0.0;
        }
    }

    males = p1.individuals[p1.individuals.sex == "M"];
    for (omuId in omuIds)
    {
        current = males[(males.tag == omuId) & (males.tagF == 1.0)];
        if (size(current) > 1)
        {
            keep = chooseDominantCandidate(current);
            extra = current[current.pedigreeID != keep.pedigreeID];
            if (size(extra) > 0)
            {
                extra.tag = 0;
                extra.tagF = 0.0;
            }
        }
    }
}

function (void) dissolveEmptyOMUs(void)
{
    if (ALLOW_OMU_DISSOLUTION == 0)
        return;

    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    adultFemales = getReproductiveFemales();

    allTagged = inds[inds.tag > 0];
    if (size(allTagged) == 0)
        return;

    omuIds = sort(unique(allTagged.tag));

    for (omuId in omuIds)
    {
        nAdultFemales = size(adultFemales[adultFemales.tag == omuId]);

        if (nAdultFemales <= OMU_DISSOLVE_FEMALES)
        {
            members = inds[inds.tag == omuId];

            activeIds = getReproductiveOMUIds();

            femaleMembers = members[members.sex == "F"];
            if (size(femaleMembers) > 0 & size(activeIds) > 0)
                femaleMembers.tag = sample(activeIds, size(femaleMembers), replace=T);

            maleMembers = members[members.sex == "M"];
            if (size(maleMembers) > 0)
            {
                if (EMPTY_OMU_INDIVIDUALS_TO_AMU == 1)
                    maleMembers.tag = 0;
                maleMembers.tagF = 0.0;
            }
        }
    }
}

function (void) splitLargeOMUs(void)
{
    if (ALLOW_OMU_SPLIT == 0)
        return;

    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    adultFemales = getReproductiveFemales();
    omuIds = getReproductiveOMUIds();

    if (size(omuIds) == 0)
        return;

    for (omuId in omuIds)
    {
        omuFemales = adultFemales[adultFemales.tag == omuId];

        if (size(omuFemales) > OMU_SPLIT_THRESHOLD)
        {
            candidates = p1.individuals[(p1.individuals.sex == "M") &
                                        (p1.individuals.tag == 0) &
                                        (p1.individuals.age >= DOM_MALE_MIN_AGE) &
                                        (p1.individuals.age <= DOM_MALE_MAX_AGE)];

            if (size(candidates) == 0 & DOM_MALE_BACKUP_ALLOWED == 1)
            {
                candidates = p1.individuals[(p1.individuals.sex == "M") &
                                            (p1.individuals.tag == 0) &
                                            (p1.individuals.age >= MALE_DOMINANCE_BACKUP_MIN_AGE) &
                                            (p1.individuals.age <= MALE_DOMINANCE_BACKUP_MAX_AGE)];
            }

            if (size(candidates) == 0 & SPLIT_REQUIRES_DOM_MALE == 1)
                next;

            newId = getNextOMUId();
            movedFemales = sample(omuFemales, OMU_SPLIT_FEMALES, replace=F);
            movedFemales.tag = newId;

            newMale = chooseDominantCandidate(candidates);
            if (!isNULL(newMale))
            {
                newMale.tag = newId;
                newMale.tagF = 1.0;
            }
        }
    }
}

function (void) replaceDominantMales(void)
{
    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    omuIds = getReproductiveOMUIds();

    if (size(omuIds) == 0)
        return;

    if (DOM_MALE_REPLACEMENT_ON_DEATH == 0 & sim.cycle > sim.getValue("forward_start_cycle"))
        return;

    for (omuId in omuIds)
    {
        current = inds[(inds.sex == "M") &
                       (inds.tag == omuId) &
                       (inds.tagF == 1.0)];

        if (size(current) > 0)
            next;

        candidates = inds[(inds.sex == "M") &
                          (inds.tag == 0) &
                          (inds.age >= DOM_MALE_MIN_AGE) &
                          (inds.age <= DOM_MALE_MAX_AGE)];

        if (size(candidates) == 0 & DOM_MALE_BACKUP_ALLOWED == 1)
        {
            candidates = inds[(inds.sex == "M") &
                              (inds.tag == 0) &
                              (inds.age >= MALE_DOMINANCE_BACKUP_MIN_AGE) &
                              (inds.age <= MALE_DOMINANCE_BACKUP_MAX_AGE)];
        }

        if (size(candidates) > 0)
        {
            newMale = chooseDominantCandidate(candidates);
            newMale.tag = omuId;
            newMale.tagF = 1.0;
        }
    }
}

function (void) updateSocialStructure(void)
{
    resetNewAdultFemaleTags();
    retireOldDominantMales();
    disperseMales();
    dissolveEmptyOMUs();
    splitLargeOMUs();
    cleanupDominantMales();
    replaceDominantMales();
}

function (logical) hasDependentInfant(object female)
{
    if (REQUIRE_NO_DEPENDENT_INFANT == 0)
        return F;

    dep = p1.individuals[(p1.individuals.age < DEPENDENCE_AGE) &
                         (p1.individuals.tagF == motherTagF(female))];

    return (size(dep) > 0);
}

function (logical) isBreedingFemale(object female)
{
    if (female.sex != "F")
        return F;

    if (female.age < FEMALE_MIN_REP_AGE | female.age > FEMALE_MAX_REP_AGE)
        return F;

    if (female.tag <= 0)
        return F;

    if (hasDependentInfant(female))
        return F;

    yearsSinceLastBirth = sim.cycle - female.tagF;

    if (yearsSinceLastBirth < INTERBIRTH_IF_INFANT_DIES)
        return F;

    if (USE_P_CONCEPTION == 1)
    {
        if (runif(1) > P_CONCEPTION)
            return F;
    }

    return T;
}

function (object) getCandidateFathers(void)
{
    inds = p1.individuals;

    males = inds[(inds.sex == "M") &
                 (inds.age >= MALE_MIN_REP_AGE) &
                 (inds.age <= MALE_MAX_REP_AGE)];

    return males;
}

function (object) chooseFather(object female)
{
    inds = p1.individuals;
    sim.setValue("last_father_category", "none");

    own = inds[(inds.sex == "M") &
               (inds.tag == female.tag) &
               (inds.tagF == 1.0) &
               (inds.age >= MALE_MIN_REP_AGE) &
               (inds.age <= MALE_MAX_REP_AGE)];

    other = inds[(inds.sex == "M") &
                 (inds.tag > 0) &
                 (inds.tag != female.tag) &
                 (inds.tagF == 1.0) &
                 (inds.age >= MALE_MIN_REP_AGE) &
                 (inds.age <= MALE_MAX_REP_AGE)];

    amu = inds[(inds.sex == "M") &
               (inds.tag == 0) &
               (inds.age >= MALE_MIN_REP_AGE) &
               (inds.age <= MALE_MAX_REP_AGE)];

    weights = c(P_OWN_OMU, P_OTHER_OMU, P_AMU);

    if (size(own) == 0)
        weights[0] = 0.0;
    if (size(other) == 0)
        weights[1] = 0.0;
    if (size(amu) == 0)
        weights[2] = 0.0;

    if (sum(weights) <= 0.0)
        return NULL;

    if (DYNAMIC_PATERNITY_RENORMALIZE == 1)
        weights = weights / sum(weights);

    category = sample(0:2, 1, replace=F, weights=weights);

    if (category == 0)
    {
        sim.setValue("last_father_category", "own_OMU");
        return sample(own, 1);
    }

    if (category == 1)
    {
        sim.setValue("last_father_category", "other_OMU");
        return sample(other, 1);
    }

    sim.setValue("last_father_category", "AMU");
    return sample(amu, 1);
}

function (void) applyForwardSurvivalScaling(void)
{
    inds = p1.individuals;
    if (size(inds) == 0)
        return;

    mortality = sim.getValue("life_mortality");
    Kt = sim.getValue("K_t");
    qHunt = sim.getValue("hunting_q_t");

    ageSurv = rep(1.0, size(inds));

    for (i in 0:(size(inds) - 1))
    {
        age = inds[i].age;

        if (age > MAX_AGE)
            ageSurv[i] = 0.0;
        else
            ageSurv[i] = 1.0 - mortality[age];
    }

    // 沿用小头鼠海豚案例中较保守的density实现：
    // density pressure基于预期年龄存活者和狩猎死亡计算，
    // 不基于age_survival * genetic_fitness。genetic fitness仍由SLiM absolute fitness施加，
    // 因此有害突变负荷不会被density补偿。
    nonGeneticSurv = ageSurv * (1.0 - qHunt);
    expectedNoDensity = sum(nonGeneticSurv);

    densityFactor = 1.0;
    if (expectedNoDensity > Kt & expectedNoDensity > 0.0)
        densityFactor = Kt / expectedNoDensity;

    inds.fitnessScaling = nonGeneticSurv * densityFactor;

    sim.setValue("density_factor", densityFactor);
}

function (float) individualGeneticFitness(object ind)
{
    hap1 = ind.haplosomes[0];
    hap2 = ind.haplosomes[1];

    muts1 = hap1.mutations;
    muts2 = hap2.mutations;

    mutsAll = unique(c(muts1, muts2));

    if (size(mutsAll) == 0)
        return 1.0;

    fitness = 1.0;

    for (mut in mutsAll)
    {
        mt = mut.mutationType;

        if (mt == m1)
            next;

        s = mut.selectionCoeff;
        h = mt.dominanceCoeff;

        in1 = any(muts1 == mut);
        in2 = any(muts2 == mut);

        if (in1 & in2)
            fitness = fitness * max(0.0, 1.0 + s);
        else
            fitness = fitness * max(0.0, 1.0 + h * s);
    }

    return fitness;
}

function (float) individual2B(object ind)
{
    hap1 = ind.haplosomes[0];
    hap2 = ind.haplosomes[1];

    muts1 = hap1.mutations;
    muts2 = hap2.mutations;

    mutsAll = unique(c(muts1, muts2));

    if (size(mutsAll) == 0)
        return 0.0;

    load = 0.0;

    for (mut in mutsAll)
    {
        mt = mut.mutationType;

        if (mt == m1)
            next;

        in1 = any(muts1 == mut);
        in2 = any(muts2 == mut);

        if (in1 != in2)
        {
            s = mut.selectionCoeff;
            h = mt.dominanceCoeff;
            load = load + abs(s) * (1.0 - h);
        }
    }

    return load;
}

function (integer) countHetOfType(object ind, object mt)
{
    muts1 = ind.haplosomes[0].mutations;
    muts2 = ind.haplosomes[1].mutations;

    a = muts1[muts1.mutationType == mt];
    b = muts2[muts2.mutationType == mt];

    shared = setIntersection(a, b);
    return size(a) + size(b) - 2 * size(shared);
}

function (integer) countHomOfType(object ind, object mt)
{
    muts1 = ind.haplosomes[0].mutations;
    muts2 = ind.haplosomes[1].mutations;

    a = muts1[muts1.mutationType == mt];
    b = muts2[muts2.mutationType == mt];

    shared = setIntersection(a, b);
    return size(shared);
}

function (integer) countHetDel(object ind)
{
    return countHetOfType(ind, m3) +
           countHetOfType(ind, m4) +
           countHetOfType(ind, m5) +
           countHetOfType(ind, m6);
}

function (integer) countHomDel(object ind)
{
    return countHomOfType(ind, m3) +
           countHomOfType(ind, m4) +
           countHomOfType(ind, m5) +
           countHomOfType(ind, m6);
}

function (integer) countSegregatingDelMuts(void)
{
    muts = sim.mutations;
    del = muts[(muts.mutationType == m3) |
               (muts.mutationType == m4) |
               (muts.mutationType == m5) |
               (muts.mutationType == m6)];
    return size(del);
}

function (integer) countFixedDelMuts(void)
{
    subs = sim.substitutions;
    delSubs = subs[(subs.mutationType == m3) |
                   (subs.mutationType == m4) |
                   (subs.mutationType == m5) |
                   (subs.mutationType == m6)];
    return size(delSubs);
}

